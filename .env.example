# ============================================================
# Financial Tracker — Environment Variables
# ============================================================
# IMPORTANT: Copy this file to `.env` and fill in real values.
#            NEVER commit `.env` to version control.
#
# Two sections below:
#   PRODUCTION — required values that must be set correctly in every environment.
#   LOCAL DEV  — defaults that work out of the box for local development.
# ============================================================


# ============================================================
# PRODUCTION — set these correctly in every environment
# ============================================================

# Database connection string.
# Production: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./financial_tracker.db

# Google OAuth credentials — from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session signing secret — keep this secret and unique per environment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-secret-change-me

# Exchange rate API key (e.g., exchangerate-api.com) — required for multi-currency features.
EXCHANGERATE_API_KEY=

# Google Cloud Storage bucket — required for file upload features.
GCS_BUCKET=

# Environment name — used to gate dev-only features and fire safety warnings.
# Must be "production" in production deployments.
ENV=development


# ============================================================
# LOCAL DEV — safe defaults for local development only
# ============================================================

# Enable verbose SQLAlchemy query logging.
DEBUG=False

# Bypass Google OAuth for local development.
# Set to true to auto-authenticate as a fixed dev user (dev@localhost) on every
# localhost request, and show the "Dev Login" button on the login page.
# One flag controls both backend middleware and frontend button.
# NEVER true in production — a CRITICAL log fires at startup if AUTH_BYPASS_ENABLED=true
# and ENV != development.
AUTH_BYPASS_ENABLED=false
