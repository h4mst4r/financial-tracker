# Configuration matrix — ARCH §5.4. Copy to `.env` for local dev (gitignored).
# Secrets are surfaced by Cloud Run from Secret Manager as plain env vars in prod;
# leave them blank here and never commit real values.

# Database (SQLite at the project root; Postgres reserved for the SaaS path)
DATABASE_URL=sqlite+aiosqlite:///./financial_tracker.db

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Sessions (HMAC signing key — generate per environment)
SESSION_SECRET=

# FX provider
EXCHANGERATE_API_KEY=

# Storage / URLs
GCS_BUCKET=financial-tracker-backups
FRONTEND_URL=http://localhost:5173

# Household bootstrap — comma-separated owner emails seeded into approved_owners
BOOTSTRAP_OWNER_EMAILS=owner@example.com

# Jobs — SERVICE_ACCOUNT_KEY is a local/manual fallback only (unset in prod, OIDC used)
SERVICE_ACCOUNT_KEY=
JOB_INVOKER_SA=scheduler@your-project.iam.gserviceaccount.com

# Operational toggles
MAINTENANCE_MODE=false
AUTH_BYPASS_ENABLED=false
ENV=development
DEBUG=false
