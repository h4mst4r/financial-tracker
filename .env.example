# ============================================================
# Financial Tracker — Environment Variables (Development)
# ============================================================
# IMPORTANT: Copy this file to `.env` and fill in real values.
#            NEVER commit `.env` to version control.

# --- Database ---
# SQLite (default for local dev).  Use postgresql+asyncpg://... for production.
DATABASE_URL=sqlite+aiosqlite:///./financial_tracker.db

# --- Google OAuth ---
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- Session / Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-secret-change-me

# --- External APIs ---
# Exchange rate API key (e.g., exchangerate-api.com)
EXCHANGERATE_API_KEY=

# --- Google Cloud Storage (optional for local dev) ---
GCS_BUCKET=

# --- Debug ---
# Set to True to enable SQLAlchemy query logging and verbose output
DEBUG=False
