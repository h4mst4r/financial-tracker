{
  "extends": ["stylelint-config-recommended"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "apply",
          "tailwind",
          "config",
          "plugin",
          "reference"
        ]
      }
    ],
    "no-duplicate-selectors": null,
    "no-descending-specificity": null
  }
}
